#Solicitud al usuario que ingrese una lista
lista = eval(input("Ingrese una lista con número par de elementos: "))

#Calcular la mitad del tamaño de la lista
mitad = len(lista) // 2

#Se calcula la primera mitad desde el inicio hasta la mitad
parte1 = lista[:mitad]

#Se calcula la segunda mitad desde la mitad hasta el final
parte2 = lista[mitad:]

#Mostrar resultado
print("Primera mitad:", parte1)
print("Segunda mitad:", parte2)